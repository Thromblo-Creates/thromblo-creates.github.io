# Copy this file to ".env" and adjust if needed. ".env" is gitignored.
# The site is fully static (GitHub Pages), so there are no runtime secrets.

# Canonical URL. Locally you can leave the default. In production this is set in
# astro.config.mjs (and can be overridden here). It drives canonical links, the
# sitemap, and share-card URLs, so it should match where the site is served.
PUBLIC_SITE_URL=https://thromblo-creates.github.io

# Base path. Leave "/" when the site is served at the domain root (org site repo
# "thromblo-creates.github.io"). If you instead deploy to a project repo served at
# https://thromblo-creates.github.io/<repo>/, set this to "/<repo>" so every link
# and asset resolves correctly. The deploy workflow can set this automatically;
# see .github/workflows/deploy.yml.
PUBLIC_BASE_PATH=/
