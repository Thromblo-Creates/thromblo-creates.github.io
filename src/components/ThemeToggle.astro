---
// Floating dark-mode toggle, pinned bottom-right on every page.
//
// The initial theme is set BEFORE paint by the inline script in BaseLayout (so
// there is no flash), which reads localStorage or the OS preference and puts
// data-theme on <html>. This component only swaps the value on click and keeps
// the button's icon + aria state in sync. The script is `is:inline` so it does
// not depend on bundled JS loading correctly under a GitHub Pages base path.
//
// Styling lives in global.css (.theme-toggle) so it can reference the root
// [data-theme] attribute for the sun/moon icon swap without scoping headaches.
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Switch to dark theme"
  aria-pressed="false"
  title="Toggle dark mode"
>
  <svg class="theme-toggle__icon theme-toggle__moon" viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"
      fill="currentColor"
    ></path>
  </svg>
  <svg class="theme-toggle__icon theme-toggle__sun" viewBox="0 0 24 24" aria-hidden="true">
    <g fill="currentColor">
      <circle cx="12" cy="12" r="4.2"></circle>
      <path
        d="M12 1.6v3M12 19.4v3M4.6 4.6 6.7 6.7M17.3 17.3l2.1 2.1M1.6 12h3M19.4 12h3M4.6 19.4 6.7 17.3M17.3 6.7l2.1-2.1"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      ></path>
    </g>
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    var root = document.documentElement;
    function sync() {
      var dark = root.getAttribute("data-theme") === "dark";
      btn.setAttribute("aria-pressed", String(dark));
      btn.setAttribute(
        "aria-label",
        dark ? "Switch to light theme" : "Switch to dark theme",
      );
    }
    sync();
    btn.addEventListener("click", function () {
      var dark = root.getAttribute("data-theme") === "dark";
      var next = dark ? "light" : "dark";
      root.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch (e) {}
      sync();
    });
  })();
</script>
