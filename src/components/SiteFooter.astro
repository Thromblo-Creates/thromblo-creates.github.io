---
import { site, isSet, activeSocials } from "../config/site";
import { withBase } from "../lib/paths";
import SocialLinks from "./SocialLinks.astro";

const year = new Date().getFullYear();
const hasSocials = activeSocials().length > 0;
---

<footer class="ft">
  <div class="wrap ft__inner">
    <div class="ft__col ft__brand">
      <span class="display ft__name">{site.owner}</span>
      <p class="tiny muted">{site.tagline}</p>
      {hasSocials && <SocialLinks variant="round" />}
    </div>

    <div class="ft__col">
      <h4 class="ft__h">Explore</h4>
      <ul class="ft__list">
        <li><a href={withBase("/projects")}>Projects</a></li>
        <li><a href={withBase("/bots")}>Bots</a></li>
        <li><a href={withBase("/devlog")}>Devlog</a></li>
        <li><a href={withBase("/contact")}>Contact</a></li>
      </ul>
    </div>

    <div class="ft__col">
      <h4 class="ft__h">Support</h4>
      <ul class="ft__list">
        {
          isSet(site.patreon) && (
            <li>
              <a href={site.patreon} target="_blank" rel="noopener noreferrer">
                Patreon
              </a>
            </li>
          )
        }
        {
          isSet(site.discordInvite) && (
            <li>
              <a href={site.discordInvite} target="_blank" rel="noopener noreferrer">
                Discord server
              </a>
            </li>
          )
        }
        {
          isSet(site.email) && (
            <li>
              <a href={`mailto:${site.email}`}>Email me</a>
            </li>
          )
        }
        {
          !isSet(site.patreon) && !isSet(site.discordInvite) && !isSet(site.email) && (
            <li class="muted tiny">Links coming soon</li>
          )
        }
      </ul>
    </div>
  </div>

  <div class="wrap ft__base">
    <span>© {year} {site.owner}. All rights reserved.</span>
    <span class="tiny muted">Built with Astro · hand-crafted with a 2010s glow.</span>
  </div>
</footer>

<style>
  .ft {
    margin-top: 3rem;
    color: var(--ink);
    border-top: 1px solid var(--line);
    background-image: linear-gradient(to bottom, var(--footer-glow), transparent);
  }
  .ft__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 1.5rem;
    padding: 2.2rem 20px 1.4rem;
  }
  .ft__name {
    font-size: 1.5rem;
  }
  .ft__brand p {
    margin: 0.2rem 0 0.9rem;
    max-width: 32ch;
  }
  .ft__h {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    margin: 0 0 0.6rem;
  }
  .ft__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
  }
  .ft__list a {
    color: var(--ink-soft);
    font-weight: 600;
  }
  .ft__list a:hover {
    color: var(--link);
  }
  .ft__base {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.9rem 20px 1.6rem;
    border-top: 1px solid var(--line);
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
  @media (max-width: 640px) {
    .ft__inner {
      grid-template-columns: 1fr 1fr;
    }
    .ft__brand {
      grid-column: 1 / -1;
    }
  }
</style>
