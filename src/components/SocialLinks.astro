---
import { activeSocials, type SocialLink } from "../config/site";

interface Props {
  /** "round" = icon-only glossy circles; "labeled" = icon + text rows. */
  variant?: "round" | "labeled";
  links?: SocialLink[];
}

const { variant = "round", links } = Astro.props;
const items = links ?? activeSocials();

// Minimal inline icon set. Shapes are simplified but recognizable; the label is
// always available via aria-label / title, and shown as text in "labeled" mode.
const icons: Record<string, string> = {
  github:
    '<path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/>',
  twitter:
    '<path d="M18.9 2H22l-7.1 8.1L23 22h-6.6l-5.2-6.8L5.3 22H2.2l7.6-8.7L1.5 2h6.8l4.7 6.2L18.9 2zm-1.2 18h1.8L7.4 3.9H5.5L17.7 20z"/>',
  bluesky:
    '<path d="M12 10.8C10.9 8.7 7.9 4.8 5 3.6 3.4 2.9 2 3.4 2 5.3c0 1.9 1.1 5.3 1.8 6.1.9 1.1 2 .9 4 .6-3 .4-3.7 2-2 3.6 1.6 1.6 3.4-.4 4.2-2.1.8 1.7 2.6 3.7 4.2 2.1 1.7-1.6 1-3.2-2-3.6 2 .3 3.1.5 4-.6.7-.8 1.8-4.2 1.8-6.1 0-1.9-1.4-2.4-3-1.7-2.9 1.2-5.9 5.1-7 7.2z"/>',
  youtube:
    '<path d="M23 7.5a3 3 0 0 0-2.1-2.1C19 5 12 5 12 5s-7 0-8.9.4A3 3 0 0 0 1 7.5 31 31 0 0 0 .6 12 31 31 0 0 0 1 16.5a3 3 0 0 0 2.1 2.1C5 19 12 19 12 19s7 0 8.9-.4A3 3 0 0 0 23 16.5 31 31 0 0 0 23.4 12 31 31 0 0 0 23 7.5zM9.8 15.3V8.7l5.7 3.3-5.7 3.3z"/>',
  itch:
    '<path d="M3 4h18l1.5 5.5a3 3 0 0 1-5.6 1.8 3 3 0 0 1-5.6 0 3 3 0 0 1-5.6 0A3 3 0 0 1 1.5 9.5L3 4zm1 8.6a4.5 4.5 0 0 0 3-1.3 4.5 4.5 0 0 0 6 0 4.5 4.5 0 0 0 6 0 4.5 4.5 0 0 0 1 .9V19a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-6.4zm5 .9v3h6v-3a6 6 0 0 1-6 0z"/>',
  kofi:
    '<path d="M5 4h12a4 4 0 0 1 0 8h-1.2A6 6 0 0 1 10 16H8a6 6 0 0 1-6-6V5a1 1 0 0 1 1-1h2zm12 2v4a2 2 0 0 0 0-4z"/>',
  discord:
    '<path d="M20 4.4A19 19 0 0 0 15.3 3l-.3.5a14 14 0 0 1 4.1 2 13 13 0 0 0-13.2 0 14 14 0 0 1 4.1-2L9.7 3A19 19 0 0 0 5 4.4 19.7 19.7 0 0 0 1.5 17.6 19.1 19.1 0 0 0 7.3 20.5l.6-1A13 13 0 0 1 5.9 18.5l.5-.4a13.6 13.6 0 0 0 11.2 0l.5.4a13 13 0 0 1-2 1l.6 1a19.1 19.1 0 0 0 5.8-2.9A19.7 19.7 0 0 0 20 4.4zM8.7 14.7a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6zm6.6 0a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6z"/>',
  patreon:
    '<path d="M15.4 2.5c-3.9 0-7 3.1-7 7 0 3.8 3.1 7 7 7s7-3.2 7-7c0-3.9-3.1-7-7-7zM2 21.5h3.4v-19H2v19z"/>',
  email:
    '<path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm9 7.2L4.3 7H3v.6l9 5.9 9-5.9V7h-1.3L12 12.2z"/>',
};

function iconFor(key: string): string {
  return icons[key] ?? icons.email;
}
---

{
  items.length > 0 && (
    <ul class={`socials socials--${variant}`}>
      {items.map((s) => (
        <li>
          <a
            href={s.href}
            class="social"
            aria-label={s.label}
            title={s.label}
            target="_blank"
            rel="noopener noreferrer me"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" set:html={iconFor(s.icon)} />
            {variant === "labeled" && <span>{s.label}</span>}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .social {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: filter 0.12s ease, transform 0.04s ease;
  }
  .social svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }
  .socials--round .social {
    width: 40px;
    height: 40px;
    justify-content: center;
    border-radius: 999px;
    color: var(--ink);
    border: 1px solid var(--line);
    background-image: linear-gradient(to bottom, var(--chip-top), var(--chip-bottom));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5), var(--shadow-sm);
  }
  .socials--round .social:hover {
    filter: brightness(1.03);
    transform: translateY(-1px);
    color: var(--link);
  }
  .socials--labeled .social {
    font-weight: 700;
  }
  .socials--labeled .social:hover {
    color: var(--link);
  }
</style>
