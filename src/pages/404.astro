---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths";
---

<BaseLayout title="Page not found" description="That page wandered off.">
  <section class="wrap notfound">
    <div class="panel panel--lg notfound__card">
      <span class="notfound__code display">404</span>
      <h1>This page wandered off.</h1>
      <p class="muted">
        The link is broken or the page moved. No worries, let us get you back on track.
      </p>
      <div class="notfound__cta">
        <a class="btn btn--primary" href={withBase("/")}>Back home</a>
        <a class="btn btn--ghost" href={withBase("/projects")}>Browse projects</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding: 3rem 20px;
  }
  .notfound__card {
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }
  .notfound__code {
    display: block;
    font-size: 5rem;
    line-height: 1;
    color: var(--teal);
    text-shadow: 0 2px 0 rgba(0, 0, 0, 0.08);
  }
  .notfound__cta {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }
</style>
